# ─────────────────────────────────────────────────────────────────────────────
# motto-outreach — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email reporting (Gmail App Password) ──────────────────────────────────────
# Create at: https://myaccount.google.com/apppasswords
# Select "Mail" + your device. 16-character password, no spaces.
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email to RECEIVE digest reports (your personal email)
REPORT_TO_EMAIL=ljm32901@gmail.com

# Email to SEND FROM (your Gmail address)
REPORT_FROM_EMAIL=ljm32901@gmail.com


# ── Reddit session (Playwright browser automation) ────────────────────────────
# fast_session.json path — defaults to data/fast_session.json
# The file must contain a valid reddit_session JWT cookie.
# Current session valid until: October 2026
REDDIT_SESSION_FILE=data/fast_session.json


# ── X / Twitter (Playwright browser automation) ───────────────────────────────
# x_session.json — created by first logging in via x_client.py
# or copy from /home/user/workspace/credentials/x_oauth.json
X_SESSION_FILE=data/x_session.json

# X account credentials (for initial login if session expires)
X_USERNAME=mottoappraisal
X_PASSWORD=


# ── Ollama (local LLM inference) ──────────────────────────────────────────────
# URL of Ollama instance. On DigitalOcean droplet: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Model name — will be created by sharpener.py from llama3.1:8b
OLLAMA_MODEL=luke-motto

# Fallback model if luke-motto not yet built
OLLAMA_FALLBACK_MODEL=llama3.1:8b


# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_NAME=Outreach
AGENT_CODENAME=OUTREACH

# Telegram fleet reporting (optional — set if using fleet chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── Safety limits (override daily_limits() defaults) ─────────────────────────
# Set to 0 to disable a channel. Leave blank to use ramp schedule.
MAX_REDDIT_DMS_DAY=
MAX_REDDIT_COMMENTS_DAY=
MAX_X_REPLIES_DAY=


# ── Debug flags ───────────────────────────────────────────────────────────────
# Set to "1" to enable verbose Playwright output
PLAYWRIGHT_DEBUG=0

# Set to "1" to use headless=False (shows browser window — only for local dev)
BROWSER_HEADFUL=0

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=
DEPLOY_ENV=prd
