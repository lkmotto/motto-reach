# =============================================================================
# Motto Appraisal Service — Content Distribution Engine
# Environment Variables
#
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# Required for all content generation in transformer.py and linkedin_company.py
# Get your key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...


# -----------------------------------------------------------------------------
# Beehiiv
# Required for beehiiv_publisher.py (newsletter drafts)
# Get your API key at: https://app.beehiiv.com/settings/integrations
# Publication ID is fixed: pub_6b0e21de-3244-40cb-a06c-b56c603e28fc
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=beehiiv_...


# -----------------------------------------------------------------------------
# X (Twitter) — OAuth2
# Required for x_poster.py
#
# Two credential files are used (not env vars, stored as JSON):
#   /home/user/workspace/credentials/x_user_token.json  — OAuth2 user context token
#   /home/user/workspace/credentials/x_oauth.json       — App credentials (API key, bearer)
#
# Run this to initialize credential templates:
#   python tools/x_poster.py --init-creds
#
# Then fill in the generated JSON files with values from:
#   https://developer.twitter.com/en/portal/projects-and-apps
# -----------------------------------------------------------------------------
# (No X env vars required — credentials loaded from JSON files above)


# -----------------------------------------------------------------------------
# X Auto-Posting Gate
# Safety switch — X posts will NEVER auto-post unless this is "true".
# Even with auto_post_x=True in distributor.distribute(), this must also be "true".
# Default: false (safe)
# -----------------------------------------------------------------------------
AUTO_POST_X=false


# -----------------------------------------------------------------------------
# LinkedIn Company Page Auto-Posting
# When "true", distributor.py will auto-rephrase and post to the Motto Appraisal
# Service company page (urn:li:organization:112763283) using the ads token.
# Requires ANTHROPIC_API_KEY for the rephrase step.
# Token path: /home/user/workspace/linkedin_poster/ads_token.txt
# Default: false (safe)
# -----------------------------------------------------------------------------
POST_TO_COMPANY_PAGE=false


# -----------------------------------------------------------------------------
# Reddit — PRAW credentials
# Required for tools/reddit_poster.py PRAW-based posting.
# Create a script-type app at: https://www.reddit.com/prefs/apps
# Credentials are also stored as JSON at:
#   /home/user/workspace/credentials/reddit_credentials.json
#
# NOTE: All Reddit posts are flagged manual_review_required=True regardless.
# PRAW credentials enable the client to be initialized but auto-posting is
# intentionally disabled to avoid subreddit promotion violations.
# -----------------------------------------------------------------------------
REDDIT_AUTO_POST=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=Opposite_Ground594
REDDIT_PASSWORD=


# -----------------------------------------------------------------------------
# Facebook Groups — Personal token
# For posting to groups Luke is a member of personally (not the page token).
# The page token (fb_page_token.txt) is used for managed groups only.
# Obtain via: https://developers.facebook.com/tools/explorer/
#   Permissions needed: groups_access_member_info, publish_to_groups
# -----------------------------------------------------------------------------
FACEBOOK_GROUPS_TOKEN=


# -----------------------------------------------------------------------------
# Optional: Logging / Debug
# Set to "1" or "true" to enable verbose logging
# -----------------------------------------------------------------------------
DISTRIBUTION_DEBUG=false


# -----------------------------------------------------------------------------
# Optional: Content customization
# Override the default CTA URL if needed
# -----------------------------------------------------------------------------
CTA_URL=https://mottoappraisal.carrd.co

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=
DEPLOY_ENV=prd
